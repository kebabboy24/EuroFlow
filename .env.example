NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Telegram: operator/admin bot receives all orders
OPERATOR_TELEGRAM_BOT_TOKEN=YOUR_OPERATOR_TELEGRAM_BOT_TOKEN
OPERATOR_TELEGRAM_CHAT_ID=YOUR_OPERATOR_OR_GROUP_CHAT_ID
OPERATOR_TELEGRAM_WEBHOOK_SECRET=YOUR_RANDOM_OPERATOR_WEBHOOK_SECRET
OPERATOR_API_SECRET=YOUR_OPERATOR_API_SECRET_FOR_REQUISITES_ENDPOINT

# Telegram: client-facing bot creates exchanges in Telegram
CLIENT_TELEGRAM_BOT_TOKEN=YOUR_CLIENT_TELEGRAM_BOT_TOKEN
CLIENT_TELEGRAM_WEBHOOK_SECRET=YOUR_RANDOM_CLIENT_WEBHOOK_SECRET

# Legacy Telegram variables are still supported as fallback
TELEGRAM_BOT_TOKEN=YOUR_LEGACY_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_LEGACY_OPERATOR_OR_GROUP_CHAT_ID

# Rate engine
EUROFLOW_RATE_MARGIN_PERCENT=6
EUROFLOW_RUB_PER_EUR_FALLBACK=100
EUROFLOW_P2P_RUB_ASSET=USDT
EUROFLOW_P2P_RUB_ASSET_TO_EUR=0.912
EUROFLOW_P2P_MIN_RUB_LIMIT=50000
EUROFLOW_UAH_TO_EUR_FALLBACK=0.0215
EUROFLOW_KZT_TO_EUR_FALLBACK=0.00182
EUROFLOW_GEL_TO_EUR_FALLBACK=0.319
EUROFLOW_TRY_TO_EUR_FALLBACK=0.0275
EUROFLOW_USD_TO_EUR_FALLBACK=0.918
EUROFLOW_USDT_TO_EUR_FALLBACK=0.912

# Optional P2P overrides for local currencies (defaults to USDT)
EUROFLOW_P2P_UAH_MIN_LIMIT=10000
EUROFLOW_P2P_KZT_MIN_LIMIT=100000
EUROFLOW_P2P_GEL_MIN_LIMIT=1000
EUROFLOW_P2P_TRY_MIN_LIMIT=10000
